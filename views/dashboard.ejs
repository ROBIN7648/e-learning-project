<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body.dashboard {
            color: var(--ink);
        }

        .page-shell {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .container {
            flex: 1;
            max-width: 1400px;
            width: 100%;
            margin: 28px auto 70px;
            padding: 0 28px;
            display: grid;
            grid-template-columns: minmax(0, 1.5fr) minmax(0, 0.9fr);
            gap: 22px;
        }

        .hero,
        .profile,
        .panel,
        .stack {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 16px;
            padding: 24px;
            border: 1px solid var(--line);
            box-shadow: var(--shadow);
        }

        .hero h1 {
            margin: 0 0 6px;
            font-size: 26px;
            font-family: "Fraunces", serif;
        }

        .hero p {
            margin: 0;
            color: var(--muted);
        }

        .stats {
            margin-top: 16px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 12px;
        }

        .stat {
            background: #fffaf4;
            border-radius: 12px;
            padding: 12px 14px;
            border: 1px solid var(--line);
        }

        .stat strong {
            display: block;
            font-size: 18px;
        }

        .stat span {
            font-size: 12px;
            color: var(--muted);
        }

        .stat small {
            display: block;
            margin-top: 4px;
            color: var(--muted);
            font-size: 12px;
        }

        .quick-links {
            margin-top: 18px;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .quick-links a {
            text-decoration: none;
            padding: 8px 14px;
            border-radius: 999px;
            background: linear-gradient(135deg, rgba(240, 97, 58, 0.15), rgba(31, 138, 112, 0.15));
            border: 1px solid var(--line);
            color: var(--ink);
            font-size: 13px;
            font-weight: 600;
        }

        .panel {
            margin-top: 18px;
        }

        .panel h2,
        .stack h2 {
            margin: 0 0 14px;
            font-size: 18px;
            font-family: "Fraunces", serif;
        }

        .course-progress {
            display: grid;
            gap: 14px;
        }

        .live-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 12px;
        }

        .live-card {
            background: #fffaf4;
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 14px;
            display: grid;
            gap: 8px;
        }

        .live-card strong {
            font-size: 14px;
        }

        .live-card span {
            font-size: 12px;
            color: var(--muted);
        }

        .course-card {
            background: #fffaf4;
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 16px;
            display: grid;
            gap: 10px;
        }

        .course-card h3 {
            margin: 0;
            font-size: 16px;
        }

        .course-meta {
            font-size: 13px;
            color: var(--muted);
        }

        .progress-bar {
            height: 8px;
            background: #efe4da;
            border-radius: 999px;
            overflow: hidden;
        }

        .progress-bar span {
            display: block;
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--accent-2));
            border-radius: 999px;
        }

        .progress-72 span { width: 72%; }
        .progress-45 span { width: 45%; }

        .task-list {
            display: grid;
            gap: 12px;
        }

        .task {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #fffaf4;
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 12px 14px;
        }

        .task strong {
            font-size: 14px;
        }

        .task span {
            font-size: 12px;
            color: var(--muted);
        }

        .stack {
            margin-top: 18px;
            display: grid;
            gap: 18px;
        }

        .resource-grid {
            display: grid;
            gap: 10px;
        }

        .resource {
            background: #fffaf4;
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 12px 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
        }

        .resource span {
            color: var(--muted);
        }

        .info-card {
            background: #fffaf4;
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 16px;
            display: grid;
            gap: 10px;
        }

        .info-card h3 {
            margin: 0;
            font-size: 16px;
        }

        .info-card p {
            margin: 0;
            color: var(--muted);
            font-size: 13px;
        }

        .tag {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 999px;
            background: rgba(240, 97, 58, 0.15);
            border: 1px solid var(--line);
            font-size: 12px;
            font-weight: 600;
            color: var(--ink);
            width: fit-content;
        }

        .profile h2 {
            margin: 0 0 8px;
            font-size: 18px;
            font-family: "Fraunces", serif;
        }

        .profile p {
            margin: 0 0 6px;
            color: var(--muted);
        }

        .actions {
            display: grid;
            gap: 8px;
            margin-top: 10px;
        }

        .actions a {
            text-decoration: none;
            padding: 10px 14px;
            background: var(--accent);
            color: white;
            border-radius: 999px;
            font-size: 13px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-weight: 600;
        }

        .actions a:hover {
            background: var(--accent-dark);
        }

        @media (max-width: 900px) {
            .container {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body class="dashboard">
    <div class="page-shell">
        <%- include("partials/navbar") %>

        <div class="container">
            <div>
                <section class="hero">
                    <h1>Welcome back, <%= user.name %></h1>
                    <p>Pick up where you left off and keep your momentum high.</p>

                    <div class="stats">
                        <div class="stat">
                            <strong>08</strong>
                            <span>Courses enrolled</span>
                            <small>2 in progress</small>
                        </div>
                        <div class="stat">
                            <strong>76%</strong>
                            <span>Weekly progress</span>
                            <small>+8% vs last week</small>
                        </div>
                        <div class="stat">
                            <strong>12</strong>
                            <span>Practice sprints</span>
                            <small>Last 7 days</small>
                        </div>
                    </div>

                    <div class="quick-links">
                        <a href="/courses">Browse courses</a>
                        <a href="/timeTable">Weekly plan</a>
                        <a href="/upComing">Upcoming lessons</a>
                        <a href="/feedback">Give feedback</a>
                    </div>
                </section>

                <section class="panel">
                    <h2>Continue learning</h2>
                    <div class="course-progress">
                        <div class="course-card">
                            <h3>JavaScript Essentials</h3>
                            <div class="course-meta">Module 4 of 7 · 12 lessons left</div>
                            <div class="progress-bar progress-72"><span></span></div>
                        </div>
                        <div class="course-card">
                            <h3>UI/UX Basics</h3>
                            <div class="course-meta">Module 2 of 5 · 6 lessons left</div>
                            <div class="progress-bar progress-45"><span></span></div>
                        </div>
                    </div>
                </section>

                <section class="panel">
                    <h2>This week focus</h2>
                    <div class="task-list">
                        <div class="task">
                            <div>
                                <strong>Finish DOM practice set</strong>
                                <span>Due Thursday</span>
                            </div>
                            <strong>3/6</strong>
                        </div>
                        <div class="task">
                            <div>
                                <strong>Submit mini project</strong>
                                <span>Due Sunday</span>
                            </div>
                            <strong>Draft</strong>
                        </div>
                        <div class="task">
                            <div>
                                <strong>Review weekly recap</strong>
                                <span>20 min</span>
                            </div>
                            <strong>New</strong>
                        </div>
                    </div>
                </section>

                <section class="panel">
                    <h2>Live classes</h2>
                    <div class="live-grid">
                        <div class="live-card">
                            <strong>Frontend clinic</strong>
                            <span>Tuesday · 6:00 PM</span>
                            <span>Topic: Layout fixes</span>
                        </div>
                        <div class="live-card">
                            <strong>JavaScript Q&A</strong>
                            <span>Thursday · 7:30 PM</span>
                            <span>Topic: Async patterns</span>
                        </div>
                        <div class="live-card">
                            <strong>Project review</strong>
                            <span>Saturday · 4:00 PM</span>
                            <span>Topic: Mini project demo</span>
                        </div>
                    </div>
                </section>

                <section class="panel">
                    <h2>Schedule & live class</h2>
                    <% if (enrollment) { %>
                        <div class="info-card">
                            <span class="tag">Enrolled</span>
                            <h3><%= enrollment.course %></h3>
                            <p><strong>Time table:</strong> <%= enrollment.schedule %></p>
                            <p><strong>Live class:</strong> <%= enrollment.live %></p>
                        </div>
                    <% } else { %>
                        <div class="info-card">
                            <h3>Enroll to unlock your schedule</h3>
                            <p>Select a course first, then your timetable and live class timings will appear here.</p>
                            <a class="btn primary" href="/courses">Enroll in a course</a>
                        </div>
                    <% } %>
                </section>
            </div>

            <aside class="profile">
                <div>
                    <h2>Your Profile</h2>
                    <p><strong>Name:</strong> <%= user.name %></p>
                    <p><strong>Email:</strong> <%= user.email %></p>
                </div>

                <div class="actions">
                    <a href="/courses">Continue Learning<span>→</span></a>
                </div>

                <div class="stack">
                    <div>
                        <h2>Streak</h2>
                        <p><strong>6 days</strong> learning streak</p>
                        <p class="course-meta">Keep the momentum for 7/7 week goal.</p>
                    </div>

                    <div>
                        <h2>Resources</h2>
                        <div class="resource-grid">
                            <div class="resource">
                                <div>Weekly recap</div>
                                <span>PDF</span>
                            </div>
                            <div class="resource">
                                <div>Practice checklist</div>
                                <span>Notion</span>
                            </div>
                            <div class="resource">
                                <div>Project brief</div>
                                <span>Doc</span>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>

    <%- include("partials/footer") %>

</body>
</html>
