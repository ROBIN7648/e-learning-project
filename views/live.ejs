<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title><%= title || "Live Classes" %></title>
	<style>
		body {
			margin: 0;
			font-family: Arial, sans-serif;
			background: #f4f4f4;
		}

		.content {
			max-width: 960px;
			margin: 48px auto;
			padding: 0 20px 40px;
		}

		.panel {
			background: white;
			border-radius: 16px;
			padding: 32px;
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
		}

		.session {
			margin-top: 18px;
			padding: 16px 18px;
			border-left: 4px solid #007bff;
			background: #f8fbff;
			border-radius: 10px;
		}
	</style>
</head>
<body>
	<%- include("partials/navbar") %>

	<main class="content">
		<section class="panel">
			<h1>Live Classes</h1>
			<p>Upcoming live sessions will appear here once scheduled.</p>

			<div class="session">
				<strong>Next session:</strong> Web Development Q&A
				<div>Friday, 7:00 PM</div>
			</div>
		</section>
	</main>

	<%- include("partials/footer") %>
</body>
</html>
