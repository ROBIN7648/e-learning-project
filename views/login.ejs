<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Login</title>

    <style>
        * {
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            margin: 0;
            font-family: Arial;
            background: #f4f4f4;
        }

        body {
            display: flex;
            flex-direction: column;
        }

        /* 🔥 MAIN CENTER FIX */
        .main {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center; /* 🔥 CENTER PERFECT */
        }

        /* 🔥 FORM CARD */
        .container {
            width: 350px;
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 0 15px rgba(0,0,0,0.2);
        }

        h2 {
            margin-bottom: 15px;
            text-align: center;
        }

        input {
            width: 100%;
            padding: 12px;
            margin: 12px 0;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

        input:focus {
            border-color: #007bff;
            outline: none;
        }

        button {
            width: 100%;
            padding: 12px;
            background: green;
            color: white;
            border: none;
            border-radius: 6px;
            margin-top: 10px;
            cursor: pointer;
            font-size: 16px;
        }

        button:hover {
            background: darkgreen;
        }

    </style>
</head>

<body>

    <%- include("partials/navbar") %>

    <!-- 🔥 MAIN CENTER -->
    <div class="main">
        <div class="container">
            <h2>Login</h2>

            <% if (typeof error !== "undefined") { %>
                <p style="color:red; text-align:center;">
                    <%= error %>
                </p>
            <% } %>

            <form action="/login" method="POST">
                <input type="email" name="email" placeholder="Enter Email" required>
                <input type="password" name="password" placeholder="Enter Password" required>
                <button type="submit">Login</button>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <%- include("partials/footer") %>

</body>

<script>
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get("success") === "1") {
        alert("Registration Successful ✅");
    }
</script>

</html>