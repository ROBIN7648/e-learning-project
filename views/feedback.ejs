<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Feedback</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: Arial;
            margin: 0;
            background: #f4f4f4;
        }

        /* 🔥 CONTAINER */
        .container {
            width: 400px;
            margin: 80px auto;
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 0 15px rgba(0,0,0,0.2);
        }

        h2 {
            margin-bottom: 20px;
            text-align: center;
        }

        /* 🔥 INPUT */
        input, textarea {
            width: 100%;
            padding: 12px;
            margin: 12px 0;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 14px;
            outline: none;
            transition: 0.3s;
        }

        input:focus, textarea:focus {
            border-color: #007bff;
            box-shadow: 0 0 5px rgba(0,123,255,0.3);
        }

        textarea {
            resize: none;
        }

        /* 🔥 BUTTON */
        button {
            width: 100%;
            padding: 12px;
            background: #28a745;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
            margin-top: 10px;
            transition: 0.3s;
        }

        button:hover {
            background: #218838;
        }

        /* 🔥 MESSAGE */
        .msg {
            text-align: center;
            margin-bottom: 10px;
            font-weight: bold;
        }

        .error {
            color: red;
        }

        .success {
            color: green;
        }

    </style>
</head>

<body>

    <%- include("partials/navbar") %>

    <!-- Form -->
    <div class="container">
        <h2>Feedback</h2>

        <% if (typeof error !== "undefined") { %>
            <p class="msg error"><%= error %></p>
        <% } %>

        <% if (typeof success !== "undefined") { %>
            <p class="msg success"><%= success %></p>
        <% } %>

        <form action="/feedback" method="POST">
            <input type="text" name="name" placeholder="Your Name" required>
            <input type="email" name="email" placeholder="Your Email" required>
            <textarea name="message" placeholder="Write your feedback..." rows="4" required></textarea>

            <button type="submit">Submit Feedback</button>
        </form>
    </div>

    <%- include("partials/footer") %>

</body>
</html>