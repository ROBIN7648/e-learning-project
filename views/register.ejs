<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Register</title>

    <style>
        * {
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            margin: 0;
            font-family: Arial;
            background: #f4f4f4;
        }

        body {
            display: flex;
            flex-direction: column;
        }

        /* 🔥 MAIN CENTER FIX */
        .main {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* 🔥 FORM CARD */
        .container {
            width: 360px;
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 0 15px rgba(0,0,0,0.2);
        }

        h2 {
            margin-bottom: 15px;
            text-align: center;
        }

        input {
            width: 100%;
            padding: 12px;
            margin: 12px 0;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

        input:focus {
            border-color: #007bff;
            outline: none;
        }

        /* 🔥 MOBILE INPUT */
        .mobile-group {
            display: flex;
            gap: 8px;
        }

        .country-code {
            width: 65px;
            text-align: center;
            background: #eee;
        }

        .mobile-number {
            flex: 1;
        }

        button {
            width: 100%;
            padding: 12px;
            background: #007bff;
            color: white;
            border: none;
            border-radius: 6px;
            margin-top: 10px;
            cursor: pointer;
            font-size: 16px;
        }

        button:hover {
            background: #0056b3;
        }

    </style>
</head>

<body>

    <%- include("partials/navbar") %>

    <!-- 🔥 MAIN CENTER -->
    <div class="main">
        <div class="container">

            <h2>Register</h2>

            <% if (typeof error !== "undefined") { %>
                <p style="color:red; text-align:center;">
                    <%= error %>
                </p>
            <% } %>

            <form action="/register" method="POST">

                <input type="text" name="name" placeholder="Enter Name" required>

                <input type="email" name="email" placeholder="Enter Email" required>

                <div class="mobile-group">
                    <input type="text" value="+91" readonly class="country-code">

                    <input type="tel" name="number" class="mobile-number"
                        placeholder="Enter Mobile Number"
                        pattern="[6-9][0-9]{9}" maxlength="10" required>
                </div>

                <input type="password" name="password" placeholder="Enter Password" required>

                <button type="submit">Register</button>

            </form>

        </div>
    </div>

    <!-- Footer -->
    <%- include("partials/footer") %>

</body>

</html>